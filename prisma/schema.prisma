generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Intelligence {
  id          String               @id @default(cuid())
  title       String
  content     String
  summary     String?
  category    String
  importance  Int                  @default(3)
  source      String?
  authorName  String               @default("匿名")
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  attachments Attachment[]
  sectors     IntelligenceSector[]
  stocks      IntelligenceStock[]
  tags        IntelligenceTag[]

  @@index([category])
  @@index([importance])
  @@index([createdAt])
}

model Source {
  id            String                 @id @default(cuid())
  code          String                 @unique
  name          String
  type          String
  isEnabled     Boolean                @default(true)
  configJson    String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  ingestionJobs IngestionJob[]
  rawDocuments  RawDocument[]
  documents     IntelligenceDocument[]
}

model IngestionJob {
  id              String        @id @default(cuid())
  sourceId        String
  jobType         String
  status          String
  startedAt       DateTime      @default(now())
  finishedAt      DateTime?
  inputCursor     String?
  outputCursor    String?
  totalFetched    Int           @default(0)
  totalNormalized Int           @default(0)
  totalInserted   Int           @default(0)
  totalSkipped    Int           @default(0)
  errorMessage    String?
  source          Source        @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  rawDocuments    RawDocument[]

  @@index([sourceId, startedAt])
  @@index([status])
}

model RawDocument {
  id             String                 @id @default(cuid())
  sourceId       String
  jobId          String?
  externalId     String
  externalUrl    String?
  publishedAt    DateTime?
  capturedAt     DateTime
  titleRaw       String?
  summaryRaw     String?
  contentRaw     String?
  authorRaw      String?
  languageRaw    String?
  rawPayload     String
  rawHash        String?
  parseStatus    String                 @default("parsed")
  createdAt      DateTime               @default(now())
  source         Source                 @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  job            IngestionJob?          @relation(fields: [jobId], references: [id], onDelete: SetNull)
  documents      IntelligenceDocument[]

  @@unique([sourceId, externalId])
  @@index([sourceId, publishedAt])
}

model IntelligenceEvent {
  id               String                 @id @default(cuid())
  canonicalTitle   String
  canonicalSummary String?
  category         String
  importance       Int                    @default(3)
  firstSeenAt      DateTime
  lastSeenAt       DateTime
  sourceCount      Int                    @default(1)
  documentCount    Int                    @default(1)
  status           String                 @default("active")
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  documents        IntelligenceDocument[]

  @@index([lastSeenAt])
  @@index([category, importance])
}

model IntelligenceDocument {
  id            String             @id @default(cuid())
  sourceId      String
  rawDocumentId String?
  eventId       String?
  title         String
  summary       String?
  content       String
  category      String
  importance    Int                @default(3)
  publishedAt   DateTime?
  capturedAt    DateTime
  authorName    String?
  language      String?
  region        String?
  isTranslated  Boolean            @default(false)
  dedupeKey     String?
  qualityScore  Float?
  metadataJson  String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  source        Source             @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  rawDocument   RawDocument?       @relation(fields: [rawDocumentId], references: [id], onDelete: SetNull)
  event         IntelligenceEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)
  tags          DocumentTag[]
  sectors       DocumentSector[]
  entities      DocumentEntity[]

  @@index([sourceId, publishedAt])
  @@index([eventId])
  @@index([category, importance])
  @@index([dedupeKey])
}

model Tag {
  id            String            @id @default(cuid())
  name          String            @unique
  color         String?
  intelligences IntelligenceTag[]
  documents     DocumentTag[]
}

model DocumentTag {
  documentId String
  tagId      String
  document   IntelligenceDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  tag        Tag                  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([documentId, tagId])
}

model IntelligenceTag {
  intelligenceId String
  tagId          String
  tag            Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)
  intelligence   Intelligence @relation(fields: [intelligenceId], references: [id], onDelete: Cascade)

  @@id([intelligenceId, tagId])
}

model DocumentSector {
  documentId String
  sectorCode String
  sectorName String
  document   IntelligenceDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@id([documentId, sectorCode])
  @@index([sectorCode])
}

model IntelligenceSector {
  intelligenceId String
  sectorCode     String
  sectorName     String
  intelligence   Intelligence @relation(fields: [intelligenceId], references: [id], onDelete: Cascade)

  @@id([intelligenceId, sectorCode])
  @@index([sectorCode])
}

model Entity {
  id             String           @id @default(cuid())
  type           String
  name           String
  normalizedName String
  ticker         String?
  exchange       String?
  metadataJson   String?
  documents      DocumentEntity[]

  @@index([type, normalizedName])
}

model DocumentEntity {
  documentId String
  entityId   String
  role       String?
  document   IntelligenceDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  entity     Entity               @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@id([documentId, entityId])
  @@index([entityId])
}

model IntelligenceStock {
  intelligenceId String
  stockSymbol    String
  stockName      String
  intelligence   Intelligence @relation(fields: [intelligenceId], references: [id], onDelete: Cascade)

  @@id([intelligenceId, stockSymbol])
  @@index([stockSymbol])
}

model Attachment {
  id             String       @id @default(cuid())
  fileName       String
  fileUrl        String
  fileType       String
  fileSize       Int
  intelligenceId String
  createdAt      DateTime     @default(now())
  intelligence   Intelligence @relation(fields: [intelligenceId], references: [id], onDelete: Cascade)
}

model Stock {
  id         String          @id @default(cuid())
  symbol     String          @unique
  name       String
  market     String
  sectorCode String
  sectorName String
  listDate   String?
  financials FinancialData[]
  valuations ValuationData[]
  watchlists WatchlistItem[]

  @@index([sectorCode])
}

model FinancialData {
  id               String @id @default(cuid())
  stockSymbol      String
  period           String
  periodDate       String
  revenue          Float?
  revenueYoy       Float?
  grossMargin      Float?
  netProfit        Float?
  netProfitYoy     Float?
  roe              Float?
  roa              Float?
  capex            Float?
  operatingCF      Float?
  totalAssets      Float?
  totalEquity      Float?
  totalDebt        Float?
  assetTurnover    Float?
  equityMultiplier Float?
  netMargin        Float?
  stock            Stock  @relation(fields: [stockSymbol], references: [symbol], onDelete: Cascade)

  @@unique([stockSymbol, period])
  @@index([stockSymbol])
  @@index([periodDate])
}

model ValuationData {
  id          String @id @default(cuid())
  stockSymbol String
  date        String
  pe          Float?
  pb          Float?
  ps          Float?
  marketCap   Float?
  price       Float?
  stock       Stock  @relation(fields: [stockSymbol], references: [symbol], onDelete: Cascade)

  @@unique([stockSymbol, date])
  @@index([stockSymbol])
}

model WatchlistItem {
  id          String   @id @default(cuid())
  userId      String   @default("default")
  stockSymbol String
  sortOrder   Int      @default(0)
  note        String?
  addedAt     DateTime @default(now())
  stock       Stock    @relation(fields: [stockSymbol], references: [symbol], onDelete: Cascade)

  @@unique([userId, stockSymbol])
  @@index([userId])
}

model MacroIndicator {
  id          String           @id @default(cuid())
  code        String           @unique
  name        String
  category    String
  country     String           @default("CN")
  unit        String
  frequency   String
  description String?
  dataPoints  MacroDataPoint[]
}

model MacroDataPoint {
  id            String         @id @default(cuid())
  indicatorCode String
  date          String
  value         Float
  indicator     MacroIndicator @relation(fields: [indicatorCode], references: [code], onDelete: Cascade)

  @@unique([indicatorCode, date])
  @@index([indicatorCode])
  @@index([date])
}
