// ==================== MAIN DASHBOARD ====================
export default function Dashboard() {
  const { resolvedTheme } = useTheme()
  const [mounted, setMounted] = useState(false)
  const [dashState, setDashState] = useState<DashboardState>(DEFAULT_STATE)

  useEffect(() => {
    setMounted(true)
    setDashState(loadDashState())
  }, [])

  useEffect(() => {
    if (mounted) persistDashState(dashState)
  }, [dashState, mounted])

  const { data: indicators = [] } = useSWR<MacroIndicator[]>('/api/macro/indicators', fetcher)

  // Auto-select indicators on first visit
  useEffect(() => {
    if (indicators.length >= 6 && !dashState.charts[0].codeX) {
      setDashState(prev => ({
        ...prev,
        charts: [
          { codeX: indicators[0].code, codeY: indicators[1].code, period: '1Y' },
          { codeX: indicators[2].code, codeY: indicators[3].code, period: '1Y' },
          { codeX: indicators[4].code, codeY: indicators[5].code, period: '1Y' },
        ],
      }))
    }
  }, [indicators, dashState.charts])

  // Fetch intelligence from API
  const newsParams = new URLSearchParams({ limit: '20' })
  if (dashState.newsFilters.category !== 'all') newsParams.set('category', dashState.newsFilters.category)
  if (dashState.newsFilters.sector !== 'all') newsParams.set('sector', dashState.newsFilters.sector)
  const { data: intelligenceData } = useSWR(`/api/intelligence?${newsParams}`, fetcher)
  const apiItems = intelligenceData?.items || []

  // Use API data if available, fallback to mock when DB is empty
  const filteredInsights = apiItems.length > 0 ? apiItems : MOCK_INSIGHTS.filter((item: any) => {
    const catOk = dashState.newsFilters.category === 'all' || item.category === dashState.newsFilters.category
    const sectorOk = dashState.newsFilters.sector === 'all' || item.sector === SW_SECTORS.find(s => s.code === dashState.newsFilters.sector)?.name
    return catOk && sectorOk
  })

  // Fetch latest macro values
  const allCodes = indicators.map(i => i.code).join(',')
  const { data: macroLatest } = useSWR(
    allCodes ? `/api/macro/data?codes=${allCodes}&limit=2` : null,
    fetcher
  )

  const isDark = resolvedTheme === 'dark'

  const updateChart = useCallback((index: number, updates: Partial<ChartConfig>) => {
    setDashState(prev => {
      const charts = [...prev.charts] as [ChartConfig, ChartConfig, ChartConfig]
      charts[index] = { ...charts[index], ...updates }
      return { ...prev, charts }
    })
  }, [])

  const updateFilter = useCallback((key: string, value: string) => {
    setDashState(prev => ({
      ...prev,
      newsFilters: { ...prev.newsFilters, [key]: value },
    }))
  }, [])

  if (!mounted) return null

  return (
    <div className="h-full p-4 flex flex-col overflow-hidden gap-4">
      {/* Row 1: Macro Indicators */}
      <MacroRow indicators={indicators} macroData={macroLatest} />

      {/* Row 2: Charts + Insights (main area) */}
      <div className="flex-1 grid grid-cols-12 gap-4 min-h-0">
        {/* Left: Charts + Sectors */}
        <div className="col-span-12 lg:col-span-9 flex flex-col gap-4 min-h-0">
          {/* Time Series Charts — constrained height */}
          <div className="rounded-2xl border border-border bg-card p-5 card-elevated">
            <div className="flex items-center justify-between mb-4">
              <span className="text-xs uppercase tracking-widest text-muted-foreground font-semibold">
                Time Series Analysis & Correlation
              </span>
              <Link href="/macro" className="text-sm text-muted-foreground hover:text-foreground transition">
                高级分析 →
              </Link>
            </div>
            <div className="grid grid-cols-3 gap-4">
              {[0, 1, 2].map(idx => (
                <ChartPanel
                  key={idx}
                  config={dashState.charts[idx]}
                  indicators={indicators}
                  isDark={isDark}
                  mockLabel={MOCK_CHART_LABELS[idx]}
                  onUpdate={(updates) => updateChart(idx, updates)}
                />
              ))}
            </div>
          </div>

          {/* Sector Performance */}
          <SectorRow />
        </div>

        {/* Right: Insights Feed */}
        <div className="col-span-12 lg:col-span-3 flex flex-col min-h-0">
          <InsightsFeed
            items={filteredInsights}
            filters={dashState.newsFilters}
            onFilterChange={updateFilter}
          />
        </div>
      </div>
    </div>
  )
}

// ==================== MACRO ROW ====================
function MacroRow({
  indicators,
  macroData,
}: {
  indicators: MacroIndicator[]
  macroData: any
}) {
  const topIndicators = indicators.slice(0, 6)

  return (
    <div className="rounded-2xl border border-border bg-card p-5 card-elevated shrink-0">
      <div className="flex items-center justify-between mb-4">
        <div className="flex items-center gap-3">
          <span className="text-xs uppercase tracking-widest text-muted-foreground font-semibold">
            Macro Indicators
          </span>
          <span className="text-xs text-up flex items-center gap-1.5">
            <span className="w-1.5 h-1.5 bg-up rounded-full animate-pulse" />
            Live
          </span>
        </div>
        <Link href="/macro" className="text-sm text-muted-foreground hover:text-foreground transition">
          全部 →
        </Link>
      </div>
      <div className="grid grid-cols-6 gap-3">
        {topIndicators.map(indicator => {
          const series = macroData?.find((d: any) => d.code === indicator.code)
          const latest = series?.data?.[0]
          const prev = series?.data?.[1]
          const change = latest && prev && prev.value !== 0
            ? ((latest.value - prev.value) / Math.abs(prev.value)) * 100
            : 0
          const isUp = change >= 0

          return (
            <div
              key={indicator.code}
              className="p-4 rounded-xl border border-border hover:bg-accent/50 transition-all duration-200 cursor-pointer"
            >
              <div className="text-xs text-muted-foreground uppercase tracking-wider mb-2 font-medium truncate">
                {indicator.code}
              </div>
              <div className="text-lg font-semibold tabular-nums tracking-tight">
                {latest?.value?.toFixed(2) ?? '—'}
              </div>
              <div className={cn(
                'text-sm font-medium tabular-nums mt-0.5',
                isUp ? 'text-up' : 'text-down'
              )}>
                {isUp ? '↑' : '↓'} {Math.abs(change).toFixed(2)}%
              </div>
            </div>
          )
        })}
      </div>
    </div>
  )
}

// ==================== CHART PANEL ====================
function ChartPanel({
  config,
  indicators,
  isDark,
  mockLabel,
  onUpdate,
}: {
  config: ChartConfig
  indicators: MacroIndicator[]
  isDark: boolean
  mockLabel: { labelX: string; labelY: string; corrLabel: string }
  onUpdate: (updates: Partial<ChartConfig>) => void
}) {
  const limit = PERIOD_MAP[config.period] || 12
  const { data } = useSWR(
    config.codeX && config.codeY
      ? `/api/macro/data?codes=${config.codeX},${config.codeY}&limit=${limit}`
      : null,
    fetcher
  )

  const seriesX = data?.find((d: any) => d.code === config.codeX)?.data || []
  const seriesY = data?.find((d: any) => d.code === config.codeY)?.data || []

  const xValues: number[] = seriesX.map((d: any) => d.value)
  const yValues: number[] = seriesY.map((d: any) => d.value)
  const xNorm = xValues.length ? normalizeValues(xValues) : []
  const yNorm = yValues.length ? normalizeValues(yValues) : []
  const correlation = xValues.length >= 2 && yValues.length >= 2 ? pearsonCorr(xValues, yValues) : 0

  const dates = seriesX.map((d: any) => {
    const date = new Date(d.date)
    return `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}`
  })

  const xIndicator = indicators.find(i => i.code === config.codeX)
  const yIndicator = indicators.find(i => i.code === config.codeY)

  const textColor = isDark ? '#636366' : '#8e8e93'

  const hasData = config.codeX && config.codeY && xNorm.length > 0

  // Use real correlation if data available, else show mock label
  const displayCorr = hasData
    ? `${correlation >= 0 ? '+' : ''}${correlation.toFixed(2)}`
    : mockLabel.corrLabel
  const corrPositive = hasData ? correlation >= 0 : mockLabel.corrLabel.startsWith('+')

  const option = {
    grid: { left: 8, right: 8, top: 10, bottom: 24 },
    tooltip: {
      trigger: 'axis' as const,
      backgroundColor: isDark ? 'rgba(18,18,20,0.94)' : 'rgba(255,255,255,0.94)',
      borderColor: isDark ? 'rgba(255,255,255,0.07)' : 'rgba(0,0,0,0.06)',
      borderWidth: 1,
      padding: 10,
      textStyle: { fontSize: 12, color: isDark ? '#f5f5f7' : '#1c1c1e' },
      formatter: (params: any) => {
        if (!Array.isArray(params) || params.length === 0) return ''
        const idx = params[0].dataIndex
        const xOrig = xValues[idx]
        const yOrig = yValues[idx]
        return `<div style="font-size:12px">${params[0].axisValue}<br/>${xIndicator?.name || config.codeX}: ${xOrig?.toFixed(2) ?? '—'}<br/>${yIndicator?.name || config.codeY}: ${yOrig?.toFixed(2) ?? '—'}</div>`
      },
    },
    xAxis: {
      type: 'category' as const,
      data: dates,
      axisLine: { show: false },
      axisTick: { show: false },
      axisLabel: {
        color: textColor,
        fontSize: 10,
        interval: Math.max(Math.floor(dates.length / 3) - 1, 0),
      },
      splitLine: { show: false },
    },
    yAxis: {
      type: 'value' as const,
      show: false,
      min: -5,
      max: 105,
    },
    series: [
      {
        name: xIndicator?.name || config.codeX,
        type: 'line' as const,
        data: xNorm,
        smooth: true,
        symbol: 'none',
        lineStyle: { color: '#3b82f6', width: 2 },
        areaStyle: { color: isDark ? 'rgba(59,130,246,0.08)' : 'rgba(59,130,246,0.10)' },
      },
      {
        name: yIndicator?.name || config.codeY,
        type: 'line' as const,
        data: yNorm,
        smooth: true,
        symbol: 'none',
        lineStyle: { color: '#ef4444', width: 2 },
        areaStyle: { color: isDark ? 'rgba(239,68,68,0.08)' : 'rgba(239,68,68,0.10)' },
      },
    ],
  }

  return (
    <div className="flex flex-col border border-border rounded-xl p-3">
      {/* Header with mock labels + correlation */}
      <div className="flex items-center justify-between mb-2">
        <div className="flex items-center gap-1.5 min-w-0">
          <span className="text-xs font-medium text-blue-400 truncate">
            {xIndicator?.name || mockLabel.labelX}
          </span>
          <span className="text-xs text-muted-foreground shrink-0">vs</span>
          <span className="text-xs font-medium text-red-400 truncate">
            {yIndicator?.name || mockLabel.labelY}
          </span>
        </div>
        <span className={cn(
          'text-sm font-semibold tabular-nums shrink-0 ml-2',
          corrPositive ? 'text-up' : 'text-down'
        )}>
          r={displayCorr}
        </span>
      </div>

      {/* Variable selectors */}
      <div className="flex items-center gap-1.5 mb-2">
        <select
          value={config.codeX}
          onChange={e => onUpdate({ codeX: e.target.value })}
          className="text-xs bg-accent border border-border rounded-lg px-2 py-1 flex-1 min-w-0 focus:outline-none text-foreground"
        >
          <option value="">X 变量</option>
          {indicators.map(i => (
            <option key={i.code} value={i.code}>{i.name}</option>
          ))}
        </select>
        <select
          value={config.codeY}
          onChange={e => onUpdate({ codeY: e.target.value })}
          className="text-xs bg-accent border border-border rounded-lg px-2 py-1 flex-1 min-w-0 focus:outline-none text-foreground"
        >
          <option value="">Y 变量</option>
          {indicators.map(i => (
            <option key={i.code} value={i.code}>{i.name}</option>
          ))}
        </select>
      </div>

      {/* Period buttons */}
      <div className="flex gap-1 mb-2">
        {Object.keys(PERIOD_MAP).map(p => (
          <button
            key={p}
            onClick={() => onUpdate({ period: p })}
            className={cn(
              'text-xs px-2.5 py-1 rounded-lg font-medium transition-all duration-200',
              config.period === p
                ? 'bg-accent text-foreground'
                : 'text-muted-foreground hover:text-foreground'
            )}
          >
            {p}
          </button>
        ))}
      </div>

      {/* Chart — fixed aspect ratio, not flex-1 */}
      <div className="w-full" style={{ height: 160 }}>
        {config.codeX && config.codeY ? (
          <ReactECharts
            option={option}
            style={{ height: '100%', width: '100%' }}
            opts={{ renderer: 'canvas' }}
          />
        ) : (
          <div className="h-full flex items-center justify-center text-sm text-muted-foreground">
            选择两个变量开始分析
          </div>
        )}
      </div>
    </div>
  )
}

// ==================== SECTOR ROW ====================
function SectorRow() {
  return (
    <div className="rounded-2xl border border-border bg-card p-5 card-elevated shrink-0">
      <div className="flex items-center justify-between mb-4">
        <span className="text-xs uppercase tracking-widest text-muted-foreground font-semibold">
          Sector Performance
        </span>
        <Link href="/stock" className="text-sm text-muted-foreground hover:text-foreground transition">
          全部 →
        </Link>
      </div>
      <div className="grid grid-cols-4 gap-3">
        {MOCK_SECTORS.map(sector => {
          const isUp = sector.change > 0
          return (
            <div
              key={sector.ticker}
              className="p-4 rounded-xl border border-border hover:bg-accent/50 transition-all duration-200"
            >
              <div className="text-sm font-medium truncate mb-1">{sector.name}</div>
              <div className="flex justify-between items-center">
                <span className="text-xs text-muted-foreground">{sector.ticker}</span>
                <span className={cn(
                  'text-base font-semibold tabular-nums',
                  isUp ? 'text-up' : 'text-down'
                )}>
                  {isUp ? '+' : ''}{sector.change.toFixed(2)}%
                </span>
              </div>
              <div className="w-full bg-accent rounded-full h-1 mt-2">
                <div
                  className={cn('h-1 rounded-full transition-all', isUp ? 'bg-up' : 'bg-down')}
                  style={{ width: `${Math.min(Math.abs(sector.change) * 20, 100)}%` }}
                />
              </div>
            </div>
          )
        })}
      </div>
    </div>
  )
}

// ==================== INSIGHTS FEED ====================
function InsightsFeed({
  items,
  filters,
  onFilterChange,
}: {
  items: any[]
  filters: { category: string; sector: string }
  onFilterChange: (key: string, value: string) => void
}) {
  const CATEGORIES = [
    { value: 'all', label: '全部类型' },
    ...INTELLIGENCE_CATEGORIES.map(c => ({ value: c.value, label: c.label })),
  ]

  const SECTOR_OPTIONS = [
    { value: 'all', label: '全部行业' },
    ...SW_SECTORS.map(s => ({ value: s.code, label: s.name })),
  ]

  const impColors: Record<number, string> = {
    5: 'bg-red-500',
    4: 'bg-orange-500',
    3: 'bg-yellow-500',
    2: 'bg-blue-500',
    1: 'bg-zinc-500',
  }

  return (
    <div className="rounded-2xl border border-border bg-card p-5 h-full flex flex-col card-elevated">
      <div className="flex justify-between items-center mb-4">
        <div className="flex items-center gap-2">
          <span className="text-xs uppercase tracking-widest text-muted-foreground font-semibold">
            Alpha Insights
          </span>
          <span className="text-xs px-2 py-0.5 rounded-lg bg-destructive/10 text-destructive font-semibold tabular-nums">
            {items.length}
          </span>
        </div>
        <Link href="/intelligence" className="text-sm text-muted-foreground hover:text-foreground transition">
          全部 →
        </Link>
      </div>

      {/* Filters: 类型 + 行业 */}
      <div className="grid grid-cols-2 gap-2 mb-4">
        <select
          value={filters.category}
          onChange={e => onFilterChange('category', e.target.value)}
          className="text-xs bg-accent border border-border rounded-lg px-2.5 py-1.5 focus:outline-none text-foreground"
        >
          {CATEGORIES.map(c => (
            <option key={c.value} value={c.value}>{c.label}</option>
          ))}
        </select>
        <select
          value={filters.sector}
          onChange={e => onFilterChange('sector', e.target.value)}
          className="text-xs bg-accent border border-border rounded-lg px-2.5 py-1.5 focus:outline-none text-foreground"
        >
          {SECTOR_OPTIONS.map(s => (
            <option key={s.value} value={s.value}>{s.label}</option>
          ))}
        </select>
      </div>

      {/* Feed */}
      <div className="flex-1 overflow-y-auto space-y-2.5 pr-1">
        {items.map((item: any) => {
          const impLevel = item.importance || 1
          const dotColor = impColors[impLevel] || 'bg-zinc-500'
          const catLabel = INTELLIGENCE_CATEGORIES.find(c => c.value === item.category)?.label || item.category

          return (
            <Link
              key={item.id}
              href={`/intelligence/${item.id}`}
              className="group block p-4 rounded-xl border border-border hover:bg-accent/50 transition-all duration-200"
            >
              <div className="flex items-center gap-2 mb-2">
                <div className={cn('w-2 h-2 rounded-full shrink-0', dotColor)} />
                <span className="text-xs text-muted-foreground uppercase tracking-wider font-medium">
                  {catLabel}
                </span>
                {item.sector && (
                  <span className="text-xs text-muted-foreground/70">· {item.sector}</span>
                )}
              </div>
              <h3 className="text-base font-medium mb-1.5 group-hover:opacity-80 transition leading-snug line-clamp-2 tracking-tight">
                {item.title}
              </h3>
              <p className="text-sm text-muted-foreground leading-relaxed line-clamp-2">
                {item.content?.replace(/[#*`]/g, '').slice(0, 150)}
              </p>
              <div className="flex justify-between items-center text-xs text-muted-foreground mt-2">
                <span>{formatDate(item.createdAt)}</span>
                {item.tags?.length > 0 && (
                  <div className="flex gap-1.5">
                    {item.tags.slice(0, 3).map((t: any, i: number) => (
                      <span key={i} className="text-xs text-muted-foreground/70">
                        {typeof t === 'string' ? t : t?.tag?.name}
                      </span>
                    ))}
                  </div>
                )}
              </div>
            </Link>
          )
        })}
        {items.length === 0 && (
          <div className="text-center text-muted-foreground text-sm py-12">
            暂无情报数据
          </div>
        )}
      </div>
    </div>
  )
}
