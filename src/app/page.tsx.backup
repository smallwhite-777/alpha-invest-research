import type { MacroIndicator } from '@/types/macro'

const fetcher = (url: string) => fetch(url).then(r => r.json())

// ==================== PERSISTENCE ====================
const STORAGE_KEY = 'alpha_dashboard_v3'

interface ChartConfig {
  codeX: string
  codeY: string
  period: string
}

interface DashboardState {
  charts: [ChartConfig, ChartConfig, ChartConfig]
  newsFilters: { category: string; sector: string }
}

const DEFAULT_STATE: DashboardState = {
  charts: [
    { codeX: '', codeY: '', period: '1Y' },
    { codeX: '', codeY: '', period: '1Y' },
    { codeX: '', codeY: '', period: '1Y' },
  ],
  newsFilters: { category: 'all', sector: 'all' },
}

function loadDashState(): DashboardState {
  if (typeof window === 'undefined') return DEFAULT_STATE
  try {
    const raw = localStorage.getItem(STORAGE_KEY)
    if (raw) {
      const parsed = JSON.parse(raw)
      return {
        charts: parsed.charts || DEFAULT_STATE.charts,
        newsFilters: { ...DEFAULT_STATE.newsFilters, ...(parsed.newsFilters || {}) },
      }
    }
  } catch { /* ignore */ }
  return DEFAULT_STATE
}

function persistDashState(state: DashboardState) {
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)) } catch { /* ignore */ }
}

// ==================== UTILITIES ====================
const PERIOD_MAP: Record<string, number> = { '6M': 6, '1Y': 12, '3Y': 36, '5Y': 60 }

function normalizeValues(values: number[]): number[] {
  const min = Math.min(...values)
  const max = Math.max(...values)
  const range = max - min || 1
  return values.map(v => ((v - min) / range) * 100)
}

function pearsonCorr(x: number[], y: number[]): number {
  const n = Math.min(x.length, y.length)
  if (n < 2) return 0
  const xs = x.slice(0, n), ys = y.slice(0, n)
  const sumX = xs.reduce((a, b) => a + b, 0)
  const sumY = ys.reduce((a, b) => a + b, 0)
  const sumXY = xs.reduce((t, xi, i) => t + xi * ys[i], 0)
  const sumX2 = xs.reduce((t, xi) => t + xi * xi, 0)
  const sumY2 = ys.reduce((t, yi) => t + yi * yi, 0)
  const num = n * sumXY - sumX * sumY
  const den = Math.sqrt((n * sumX2 - sumX * sumX) * (n * sumY2 - sumY * sumY))
  return den === 0 ? 0 : num / den
}

