# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# uploads
/public/uploads/*
!/public/uploads/.gitkeep

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# Large knowledge base files - use cloud storage
/Knowledgebase/
/daily_quote_by_code_csv/
/Reserach Reports/
/News/
/Financial Reports/

# Python cache
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Database files
*.db
dev.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Claude Code
.claude/
.workbuddy/

# Temporary files
*.tmp
*.temp
debug_api_output.txt
test_results*.json
*.bat
